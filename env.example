# Copy to .env and edit.   cp .env.example .env

# --- Diarization (assigning sentences to speakers) ---------------------------
# Needed ONLY for speaker labels. Get a free token at huggingface.co/settings/tokens
# and click "Agree and access" on BOTH:
#   https://huggingface.co/pyannote/segmentation-3.0
#   https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
DIARIZE=1
# Default speaker-count hints (improve diarization). Usually leave these blank and
# set the count PER FILE via the filename instead — e.g.  standup.3spk.mp3  (exactly
# 3), panel.2-5spk.mp3  (2 to 5). The filename marker overrides these and is stripped
# from the output name (standup.3spk.mp3 -> standup.txt).
MIN_SPEAKERS=
MAX_SPEAKERS=

# --- Transcription -----------------------------------------------------------
LANGUAGE=pl            # pl, en, de, ... or leave empty for autodetect
# MODEL=large-v3       # GPU default; override here if you want
# CPU_MODEL=small      # CPU profile default; base < small < medium < large-v3

# Quality (if you have GPU headroom — crank these). These are DEFAULTS for every file;
# override per-recording with a "<name>.txt" instruction file (see instruction.example.txt).
# BEAM_SIZE=10         # default 5; higher = more accurate, slightly slower
# Baseline vocabulary that's true for ALL your recordings (names, stack, products):
# INITIAL_PROMPT=

# --- Behaviour ---------------------------------------------------------------
WATCH=1                # 1 = stay running and watch ./input ; 0 = process once and exit
