# Copy to .env and edit.   cp .env.example .env

# --- Diarization (assigning sentences to speakers) ---------------------------
# Needed ONLY for speaker labels. Get a free token at huggingface.co/settings/tokens
# and click "Agree and access" on BOTH:
#   https://huggingface.co/pyannote/segmentation-3.0
#   https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
DIARIZE=1
# Optional hints — set if you KNOW how many people are talking (improves results):
MIN_SPEAKERS=
MAX_SPEAKERS=

# --- Transcription -----------------------------------------------------------
LANGUAGE=pl            # pl, en, de, ... or leave empty for autodetect
# MODEL=large-v3       # GPU default; override here if you want
# CPU_MODEL=small      # CPU profile default; base < small < medium < large-v3

# --- Behaviour ---------------------------------------------------------------
WATCH=1                # 1 = stay running and watch ./input ; 0 = process once and exit
